<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Banner -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">

            <ImageView
                android:id="@+id/mod_fixes_banner_iv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/banner_default"/>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Double path fix card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Title + help -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mod_fix_group_double_path"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="13sp"/>

                        <ImageButton
                            style="@style/AppTheme.ImageButton"
                            android:id="@+id/mod_fixes_help_ib"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true"
                            android:src="@drawable/mt_icon_help"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/mod_fix_double_path_hint"
                        android:textSize="11sp"
                        android:textColor="?android:attr/textColorSecondary"/>

                    <!-- Instance -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/install_mod_group_instance"
                        android:textAppearance="?attr/textAppearanceBodySmall"/>

                    <Spinner
                        android:id="@+id/mod_fixes_instance_spinner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <!-- File picker -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/install_mod_zip_label"
                        android:textAppearance="?attr/textAppearanceBodySmall"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <EditText
                            android:id="@+id/mod_fixes_zip_path_et"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="13sp"
                            android:hint="@string/game_instance_no_file_selected"
                            android:enabled="false"
                            android:focusable="false"
                            android:clickable="false"
                            android:cursorVisible="false"
                            android:inputType="none"/>

                        <ImageButton
                            style="@style/AppTheme.ImageButton"
                            android:id="@+id/mod_fixes_browse_ib"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/mt_icon_folder_open"/>

                    </LinearLayout>

                    <Button
                        android:id="@+id/mod_fixes_install_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:minWidth="160dp"
                        android:text="@string/optimization_install"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>