<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gap="12dp">

        <!-- Группа 1: Рендеринг -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gap="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_group_rendering"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorPrimary"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:id="@+id/settings_render_hint_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_render_hint"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"/>

                <ImageButton
                    style="@style/AppTheme.ImageButton"
                    android:id="@+id/settings_render_hint_help_ib"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"
                    android:src="@drawable/mt_icon_help"/>

                <TextView
                    android:id="@+id/settings_renderer_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_renderer"/>

                <Spinner
                    android:id="@+id/settings_renderer_s"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/settings_vulkan_driver_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_vulkan_driver"/>

                <Spinner
                    android:id="@+id/settings_vulkan_driver_s"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/settings_resolution_scale_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_resolution_scale"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <SeekBar
                        android:id="@+id/settings_resolution_scale_sb"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:min="25"
                        android:max="100"/>

                    <TextView
                        android:id="@+id/settings_resolution_scale_percent_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        tools:text="100%"/>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Группа 2: Дополнительно -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gap="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_group_advanced"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorPrimary"
                    android:paddingBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/settings_jargs_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JVM arguments"/>

                    <ImageButton
                        android:id="@+id/settings_jargs_info"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/mt_icon_help"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="About"/>

                </LinearLayout>

                <EditText
                    android:id="@+id/settings_jargs_et"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="-Xmx3G -Xms2G -Xmn1G"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:lines="2"
                    android:maxLines="3"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/settings_env_vars_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_env_vars"/>

                    <ImageButton
                        android:id="@+id/settings_env_vars_info"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/mt_icon_help"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="About"/>

                </LinearLayout>

                <EditText
                    android:id="@+id/settings_env_vars_et"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/settings_env_vars_hint"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:lines="2"
                    android:maxLines="5"
                    android:gravity="top"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/settings_debug_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_debug_mode"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Группа 3: Управление -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gap="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_group_controls"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorPrimary"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/touch_controls_description"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/touch_controls_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/touch_controls_switch_label"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Группа 4: Звук -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gap="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_group_audio"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorPrimary"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:id="@+id/settings_audio_api_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_audio_api"/>

                <Spinner
                    android:id="@+id/settings_audio_api_s"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
