<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Banner -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">

            <ImageView
                android:id="@+id/optimization_banner_iv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/banner_default"/>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- JVM Args -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/optimization_group_jvm"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="@string/optimization_jvm_hint"
                        android:textSize="11sp"
                        android:textColor="?android:attr/textColorSecondary"/>

                    <!-- 4 GB subgroup label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/optimization_jvm_4gb_label"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textStyle="bold"/>

                    <!-- 4 GB Balanced -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/optimization_jvm_balanced_label"
                        android:textSize="11sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:id="@+id/optimization_jvm_4g_balanced_tv"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="-Xms512M -Xmx2048M -XX:+UseZGC"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:textColor="?android:attr/textColorSecondary"/>

                        <Button
                            android:id="@+id/optimization_jvm_4g_balanced_copy_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="0dp"
                            android:text="@string/optimization_copy"
                            android:textSize="11sp"
                            style="@style/Widget.Material3.Button.TonalButton"/>

                    </LinearLayout>

                    <!-- 4 GB Aggressive -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/optimization_jvm_aggressive_label"
                        android:textSize="11sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/optimization_jvm_4g_aggressive_tv"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="-Xms512M -Xmx2560M -XX:+UseZGC -XX:MaxDirectMemorySize=384m"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:textColor="?android:attr/textColorSecondary"/>

                        <Button
                            android:id="@+id/optimization_jvm_4g_aggressive_copy_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="0dp"
                            android:text="@string/optimization_copy"
                            android:textSize="11sp"
                            style="@style/Widget.Material3.Button.TonalButton"/>

                    </LinearLayout>

                    <!-- 6 GB subgroup label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/optimization_jvm_6gb_label"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textStyle="bold"/>

                    <!-- 6 GB Balanced -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/optimization_jvm_balanced_label"
                        android:textSize="11sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:id="@+id/optimization_jvm_6g_balanced_tv"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="-Xms512M -Xmx3072M -XX:+UseZGC"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:textColor="?android:attr/textColorSecondary"/>

                        <Button
                            android:id="@+id/optimization_jvm_6g_balanced_copy_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="0dp"
                            android:text="@string/optimization_copy"
                            android:textSize="11sp"
                            style="@style/Widget.Material3.Button.TonalButton"/>

                    </LinearLayout>

                    <!-- 6 GB Aggressive -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/optimization_jvm_aggressive_label"
                        android:textSize="11sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/optimization_jvm_6g_aggressive_tv"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="-Xms512M -Xmx4096M -XX:+UseZGC -XX:MaxDirectMemorySize=512m"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:textColor="?android:attr/textColorSecondary"/>

                        <Button
                            android:id="@+id/optimization_jvm_6g_aggressive_copy_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="0dp"
                            android:text="@string/optimization_copy"
                            android:textSize="11sp"
                            style="@style/Widget.Material3.Button.TonalButton"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/optimization_open_settings_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/optimization_open_settings"
                        android:textSize="12sp"
                        android:textColor="?attr/colorPrimary"
                        android:background="?attr/selectableItemBackground"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BetterFPS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/optimization_group_betterfps"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="13sp"/>

                        <ImageButton
                            style="@style/AppTheme.ImageButton"
                            android:id="@+id/optimization_betterfps_help_ib"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true"
                            android:src="@drawable/mt_icon_help"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/optimization_betterfps_hint"
                        android:textSize="11sp"
                        android:textColor="?android:attr/textColorSecondary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/install_mod_group_instance"
                        android:textAppearance="?attr/textAppearanceBodySmall"/>

                    <Spinner
                        android:id="@+id/optimization_betterfps_instance_spinner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/optimization_betterfps_file_label"
                        android:textAppearance="?attr/textAppearanceBodySmall"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <EditText
                            android:id="@+id/optimization_betterfps_path_et"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="13sp"
                            android:hint="@string/game_instance_no_file_selected"
                            android:enabled="false"
                            android:focusable="false"
                            android:clickable="false"
                            android:cursorVisible="false"
                            android:inputType="none"/>

                        <ImageButton
                            style="@style/AppTheme.ImageButton"
                            android:id="@+id/optimization_betterfps_browse_ib"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/mt_icon_folder_open"/>

                    </LinearLayout>

                    <Button
                        android:id="@+id/optimization_betterfps_install_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:minWidth="160dp"
                        android:text="@string/optimization_install"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>