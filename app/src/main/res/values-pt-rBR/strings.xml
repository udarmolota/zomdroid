    <string name="install_mod_zip_warning">O ZIP deve conter mod.info no nível raiz.</string>

    <string name="install_mod_zip_help_title">Estrutura do arquivo de mod</string>

    <string name="install_mod_zip_help_message">
        \u2705 Exemplos corretos:\n\n

        Mod único:\n
        ModName/\n
        \u00A0\u00A0mod.info\n
        \u00A0\u00A0media/\n
        \u00A0\u00A0scripts/\n\n

        Vários mods em um ZIP:\n
        ModA/\n
        \u00A0\u00A0mod.info\n
        ModB/\n
        \u00A0\u00A0mod.info\n\n

        \u274C Exemplos incorretos:\n\n

        Pasta extra de agrupamento:\n
        Downloads/\n
        \u00A0\u00A0ModName/\n
        \u00A0\u00A0\u00A0\u00A0mod.info\n\n

        Raiz do mod ausente:\n
        media/\n
        scripts/\n
        (sem mod.info na raiz)
    </string>

